# MemoryAI Environment Configuration
# Copy to .env and fill in the values

# ── Database ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memoryai
POSTGRES_USER=memoryai
POSTGRES_PASSWORD=change_me_strong_password

DATABASE_URL=postgresql://memoryai:change_me_strong_password@localhost:5432/memoryai

# ── Redis ──────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

REDIS_URL=redis://:change_me_redis_password@localhost:6379

# ── API Server ─────────────────────────────
NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_min_32_chars_long

# Admin API key (first user key — generate with: openssl rand -hex 32)
ADMIN_API_KEY=change_me_admin_api_key

# CORS — comma-separated origins or * for all
CORS_ORIGINS=*

# ── Embeddings ─────────────────────────────
# Provider: ollama | gemini | openai
EMBEDDING_PROVIDER=ollama

# Ollama (local — recommended for privacy)
OLLAMA_BASE_URL=http://localhost:11434
# Options: nomic-embed-text (768d), mxbai-embed-large (1024d), bge-m3 (1024d multilingual)
OLLAMA_EMBED_MODEL=nomic-embed-text
# Embedding vector dimensions (must match the model above)
EMBED_DIMENSIONS=768

# Gemini embedding (alternative)
# EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_EMBED_MODEL=text-embedding-004

# OpenAI embedding (alternative)
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Distillation LLM ───────────────────────
# Used for auto-extracting facts from sessions
# Provider: ollama | gemini | openai | anthropic
DISTILL_PROVIDER=ollama
DISTILL_MODEL=qwen2.5:7b

# DISTILL_PROVIDER=gemini
# DISTILL_MODEL=gemini-2.0-flash-exp
# GEMINI_API_KEY=your_gemini_api_key

# DISTILL_PROVIDER=anthropic
# DISTILL_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Session Auto-Distillation ──────────────
# Trigger distillation after N minutes of inactivity
DISTILL_INACTIVITY_MINUTES=15
# Or after every N messages
DISTILL_EVERY_N_MESSAGES=50

# ── MCP Server ─────────────────────────────
# Public URL where the MCP server is accessible
# Used for Antigravity/Claude Code MCP config auto-generation
MCP_SERVER_URL=http://localhost:3001/mcp

# ── Security ───────────────────────────────
# Max memories returned per search
SEARCH_MAX_RESULTS=20
# Rate limiting (requests per minute per API key)
RATE_LIMIT_RPM=120

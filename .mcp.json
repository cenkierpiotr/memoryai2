{
  "mcpServers": {
    "local-ai": {
      "type": "stdio",
      "command": "python3",
      "args": ["/config/.claude/hooks/mcp-local-ai.py"],
      "env": {
        "MCP_VERSION": "2"
      }
    },
    "memoryai": {
      "type": "stdio",
      "command": "node",
      "args": ["/config/memoryai/packages/api/dist/mcp/server.js"],
      "env": {}
    }
  }
}
